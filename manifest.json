{
  "manifest_version": 2,
  "name": "Netflix Subtitle Translator",
  "version": "1.0",
  "description": "Automatically translates Netflix English subtitles to Simplified Chinese using OpenAI GPT.",
  "permissions": [
    "storage",
    "*://www.netflix.com/*",
    "*://*.nflxvideo.net/*"
  ],
  "browser_action": {
    "default_title": "Netflix Subtitle Translator",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon.svg",
      "96": "icons/icon.svg"
    }
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "web_accessible_resources": ["injected.js"],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["*://www.netflix.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "netflix-subtitle-translator@extension",
      "strict_min_version": "57.0"
    }
  }
}
